{
  "name": "dejayvu",
  "version": "0.2.0",
  "private": true,
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": "24.x"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.x",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": "11.17.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "test": "node --import tsx --test tests/unit/*.test.ts",
    "test:integration": "corepack npm run db:test:reset && NODE_ENV=test node --import tsx --test --test-concurrency=1 tests/integration/*.test.ts && corepack npm run db:test:verify",
    "test:e2e:prepare": "corepack npm run db:test:reset && corepack npm run prisma:generate && tsx tests/e2e/seed.ts && tsx scripts/clear-next-build.ts && corepack npm run build",
    "test:e2e:run": "playwright test",
    "test:e2e": "corepack npm run test:e2e:prepare && corepack npm run test:e2e:run && corepack npm run db:test:verify",
    "check:public-tree": "node scripts/check-public-tree.mjs",
    "check:workflows": "github-actionlint",
    "check:migrations": "node scripts/check-migration-history.mjs",
    "check:aws-contract": "tsx scripts/assert-aws-contract.ts",
    "check:naming": "tsx scripts/check-domain-language.ts",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "media:prewarm:dry-run": "tsx scripts/prewarm-media-variants.ts",
    "media:prewarm": "tsx scripts/prewarm-media-variants.ts --apply",
    "assets:slurmdeck-og": "node scripts/generate-slurmdeck-og.mjs",
    "cdk": "cdk --app \"tsx infra/bin/media-stack.ts\"",
    "infra:synth": "cdk --app \"tsx infra/bin/media-stack.ts\" synth --quiet",
    "db:test:reset": "tsx scripts/assert-test-database.ts && prisma migrate reset --force",
    "db:test:status": "tsx scripts/assert-test-database.ts && prisma migrate status",
    "db:test:diff": "tsx scripts/assert-test-database.ts && prisma migrate diff --from-config-datasource --to-schema prisma/schema.prisma --exit-code",
    "db:test:verify": "corepack npm run db:test:status && corepack npm run db:test:diff",
    "db:migrate:dev": "tsx scripts/assert-development-database.ts && prisma migrate dev",
    "db:migrate:deploy": "tsx scripts/assert-production-migration-ledger.ts && prisma migrate deploy",
    "db:migrate:preflight": "tsx scripts/assert-production-migration-ledger.ts",
    "db:migrate:status": "tsx scripts/assert-production-database.ts && prisma migrate status",
    "db:migrate:diff": "tsx scripts/assert-production-database.ts && prisma migrate diff --from-config-datasource --to-schema prisma/schema.prisma --exit-code",
    "db:baseline:resolve": "tsx scripts/resolve-production-baseline.ts",
    "db:migration:manifest": "node scripts/write-migration-manifest.mjs",
    "db:mask-logs": "tsx scripts/mask-database-logs.ts",
    "release:provenance": "tsx scripts/write-release-provenance.ts",
    "release:verify-vercel": "tsx scripts/verify-vercel-release.ts",
    "db:target:fingerprint": "tsx scripts/print-database-fingerprint.ts",
    "prisma:generate": "prisma generate",
    "prisma:studio": "tsx scripts/assert-development-database.ts && prisma studio"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{css,md,mdx,json,yml,yaml}": "prettier --write",
    "prisma/schema.prisma": "prisma format --schema"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1067.0",
    "@aws-sdk/client-s3": "^3.1067.0",
    "@aws-sdk/client-sts": "^3.1085.0",
    "@aws-sdk/lib-storage": "^3.1067.0",
    "@aws-sdk/s3-presigned-post": "^3.1067.0",
    "@aws-sdk/s3-request-presigner": "^3.1067.0",
    "@gsap/react": "^2.1.2",
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "@internationalized/date": "^3.12.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "@sentry/nextjs": "^10.63.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "exifreader": "^4.41.0",
    "gsap": "^3.15.0",
    "next": "^16.2.9",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "pg-connection-string": "^2.14.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "reading-time": "^1.5.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.20",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "aws-cdk": "^2.1126.0",
    "aws-cdk-lib": "^2.258.1",
    "constructs": "^10.6.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "github-actionlint": "1.7.12",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "pg": "^8.21.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
