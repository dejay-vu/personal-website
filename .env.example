# Local development only.
# Copy this file to .env.local and fill in values locally.
# Production/Preview values belong in Vercel Project Settings, not in Git.

# Database
DATABASE_URL=
POSTGRES_URL_NON_POOLING=
# Protected database workflows compare the direct target to this SHA-256.
PRODUCTION_DATABASE_FINGERPRINT=
# Destructive remote test resets and development migrations require an exact target approval.
TEST_DATABASE_RESET_APPROVAL=
DEVELOPMENT_DATABASE_FINGERPRINT=

# Auth.js / GitHub OAuth
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
NEXTAUTH_URL=http://localhost:3000
ADMIN_GITHUB_IDS=

# Vercel Cron authentication
CRON_SECRET=

# AWS / S3 media
AWS_REGION=
AWS_DEFAULT_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional when temporary STS credentials are used.
AWS_SESSION_TOKEN=
AWS_EXPECTED_ACCOUNT_ID=
# Legacy domain cleanup only; not required by Vercel runtime or release validation.
AWS_MAINTENANCE_PRINCIPAL_ARN_PREFIX=
NEXT_PUBLIC_S3_REGION=
NEXT_PUBLIC_S3_BUCKET_NAME=
S3_BUCKET_NAME=
NEXT_PUBLIC_CLOUDFRONT_RESIZER_URL=
NEXT_PUBLIC_CLOUDFRONT_S3_URL=
CLOUDFRONT_ORIGINALS_DISTRIBUTION_ID=
CLOUDFRONT_TRANSFORMED_DISTRIBUTION_ID=
TRANSFORMED_IMAGE_BUCKET_NAME=

# Contact form
RESEND_API_KEY=
CONTACT_S3_BUCKET_NAME=
CONTACT_ATTACHMENT_URL_EXPIRES_SECONDS=259200
# Keep rate limiting ON. Only set to true temporarily for local testing.
CONTACT_RATE_LIMIT_DISABLED=false
